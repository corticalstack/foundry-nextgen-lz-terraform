                    <mxGeometry x="-2006" y="407" width="659" height="183" as="geometry"/>
                </mxCell>
                <mxCell id="iso_text" value="VNet: all PaaS services accessible only via Private Endpoints — no public internet route&lt;br&gt;Subnet: network segments with delegation rules; PE subnet has network_policies=Disabled&lt;br&gt;Private DNS Zones resolve PaaS FQDNs to private IPs (10.0.0.x NIC) instead of public Azure IPs&lt;br&gt;Bastion → Jump VM only route for human access; NAT GW provides outbound-only internet for Jump VM&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;Resource Groups: rg-contoso-core-{suffix} (core) | rg-contoso-multi-{suffix} (spoke)&lt;/span&gt;&lt;br style=&quot;color: rgb(63, 63, 63); scrollbar-color: rgb(226, 226, 226) rgb(251, 251, 251);&quot;&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;Suffix: 6-char hex (SHA-256 of subscription ID) | Tags: environment=dev, customer, workload=foundry, managed_by=terraform&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;" style="text;html=1;align=left;verticalAlign=top;fontSize=9;" parent="isolation" vertex="1">
                    <mxGeometry x="8" y="28" width="1144" height="62" as="geometry"/>
                </mxCell>
